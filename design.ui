          <widget class="QWidget" name="tab_leave_mgt">
           <attribute name="title"><string>🎌 Leave Management</string></attribute>
           <layout class="QHBoxLayout" name="horizontalLayout_leave">
            <property name="spacing"><number>20</number></property>
            <item>
             <layout class="QVBoxLayout" name="verticalLayout_leave_form">
              <item><widget class="QLabel" name="lbl_leave_form_title"><property name="font"><font><family>Segoe UI</family><bold>true</bold></font></property><property name="text"><string>Assign Leave</string></property></widget></item>
              <item><widget class="QLabel" name="lbl_leave_user"><property name="text"><string>Search by Name / ID:</string></property></widget></item>
              <item><widget class="QComboBox" name="combo_leave_user"><property name="editable"><bool>true</bool></property></widget></item>
              <item><widget class="QLabel" name="lbl_leave_date"><property name="text"><string>Date:</string></property></widget></item>
              <item><widget class="QDateEdit" name="dateEdit_leave"><property name="displayFormat"><string>dd-MM-yyyy</string></property><property name="calendarPopup"><bool>true</bool></property></widget></item>
              <item><widget class="QLabel" name="lbl_leave_type"><property name="text"><string>Leave Type:</string></property></widget></item>
              <item>
               <widget class="QComboBox" name="combo_leave_type">
