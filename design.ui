  <property name="windowTitle">
   <string>FaceRec Pro - Attendance &amp; Security</string>
  </property>
  <property name="styleSheet">
   <string>
    /* Global Dark Theme Settings */
    QMainWindow { background-color: #1e1e2e; }
    QWidget { color: #cdd6f4; font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; }
    
    /* Tab Widget Styling */
    QTabWidget::pane { border: 1px solid #313244; background: #1e1e2e; border-radius: 8px; top: -1px; }
    QTabBar::tab { background: #313244; color: #a6adc8; padding: 10px 20px; margin-right: 2px; border-top-left-radius: 6px; border-top-right-radius: 6px; font-weight: bold; font-size: 14px; }
    QTabBar::tab:selected { background: #89b4fa; color: #11111b; }
    QTabBar::tab:hover:!selected { background: #45475a; }

    /* Input Fields */
    QLineEdit, QSpinBox, QTextEdit { background-color: #313244; border: 1px solid #45475a; border-radius: 5px; padding: 8px; color: #cdd6f4; }
    QLineEdit:focus, QSpinBox:focus, QTextEdit:focus { border: 1px solid #89b4fa; }

    /* Buttons */
    QPushButton { background-color: #89b4fa; color: #11111b; border: none; border-radius: 5px; padding: 10px; font-weight: bold; }
    QPushButton:hover { background-color: #b4befe; }
    QPushButton:pressed { background-color: #74c7ec; }
    QPushButton#btn_reg_save { background-color: #a6e3a1; color: #11111b; } 
    QPushButton#btn_reg_save:hover { background-color: #94e2d5; }
    QPushButton#btn_scan_stop { background-color: #f38ba8; color: #11111b; } 
    QPushButton#btn_scan_stop:hover { background-color: #eba0ac; }
    
    /* Labels */
    QLabel { font-weight: bold; }
    QLabel#lbl_reg_preview, QLabel#lbl_live_camera, QLabel#lbl_res_image { border: 2px dashed #45475a; background-color: #181825; border-radius: 10px; }
    QLabel#lbl_res_name { font-size: 24px; color: #89b4fa; }
    QLabel#lbl_status { font-size: 16px; color: #a6e3a1; }

    /* Table Widget Styling */
    QTableWidget { background-color: #181825; alternate-background-color: #1e1e2e; color: #cdd6f4; gridline-color: #45475a; border: 1px solid #313244; border-radius: 5px; outline: 0; }
    QTableWidget::item:selected { background-color: #89b4fa; color: #11111b; }
    QHeaderView::section { background-color: #313244; color: #a6adc8; padding: 5px; border: none; border-right: 1px solid #45475a; border-bottom: 1px solid #45475a; font-weight: bold; font-size: 13px; }
    
    /* User Tab Buttons */
    QPushButton#btn_user_leave { background-color: #f9e2af; color: #11111b; } 
    QPushButton#btn_user_leave:hover { background-color: #f2cd84; }
    QPushButton#btn_user_edit { background-color: #cba6f7; color: #11111b; } 
    QPushButton#btn_user_edit:hover { background-color: #b48ead; }

    QPushButton#btn_refresh_att { background-color: #89dceb; color: #11111b; }
    QPushButton#btn_refresh_att:hover { background-color: #74c7ec; }

    
   </string>
  </property>
  
