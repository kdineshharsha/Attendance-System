<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1054</width>
    <height>750</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>FaceRec Pro - Enterprise Edition</string>
  </property>
  <property name="styleSheet">
   <string>
    /* Global Dark Theme Settings */
    QMainWindow { background-color: #1e1e2e; }
    QWidget { color: #cdd6f4; font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; }
    
    /* MAIN Tab Widget Styling */
    QTabWidget#tabWidget::pane { border: 2px solid #45475a; background: #1e1e2e; border-radius: 8px; top: -1px; }
    QTabWidget#tabWidget &gt; QTabBar::tab { background: #313244; color: #a6adc8; padding: 12px 25px; margin-right: 4px; border-top-left-radius: 8px; border-top-right-radius: 8px; font-weight: bold; font-size: 14px; }
    QTabWidget#tabWidget &gt; QTabBar::tab:selected { background: #89b4fa; color: #11111b; border-bottom: 2px solid #89b4fa; }
    QTabWidget#tabWidget &gt; QTabBar::tab:hover:!selected { background: #45475a; color: #cdd6f4; }

    /* SUB-TAB (Nested) Styling - Pill Shape */
    QTabWidget#tabWidget_attendance::pane, QTabWidget#tabWidget_users::pane { border: 1px solid #313244; background: #181825; border-radius: 8px; top: 12px; }
    QTabWidget#tabWidget_attendance &gt; QTabBar::tab, QTabWidget#tabWidget_users &gt; QTabBar::tab { background: #1e1e2e; border: 1px solid #45475a; color: #bac2de; padding: 8px 20px; margin-right: 12px; border-radius: 15px; font-weight: bold; font-size: 12px; }
    
    /* Unique Colors for Sub-tabs */
    QTabWidget#tabWidget_attendance &gt; QTabBar::tab:selected { background: #a6e3a1; border: 1px solid #a6e3a1; color: #11111b; } /* Green */
    QTabWidget#tabWidget_users &gt; QTabBar::tab:selected { background: #cba6f7; border: 1px solid #cba6f7; color: #11111b; } /* Purple */
    
    QTabWidget#tabWidget_attendance &gt; QTabBar::tab:hover:!selected, QTabWidget#tabWidget_users &gt; QTabBar::tab:hover:!selected { background: #313244; }

    /* Input Fields */
    QLineEdit, QSpinBox, QTextEdit, QDateEdit, QComboBox { background-color: #313244; border: 1px solid #45475a; border-radius: 5px; padding: 8px; color: #cdd6f4; }
    QLineEdit:focus, QSpinBox:focus, QTextEdit:focus, QDateEdit:focus, QComboBox:focus { border: 1px solid #89b4fa; }

    /* Buttons */
    QPushButton { background-color: #89b4fa; color: #11111b; border: none; border-radius: 5px; padding: 10px; font-weight: bold; }
    QPushButton:hover { background-color: #b4befe; }
    QPushButton:pressed { background-color: #74c7ec; }
    QPushButton:disabled { background-color: #45475a; color: #a6adc8; }
    
    /* Specific Button Styles */
    QPushButton#btn_reg_save, QPushButton#btn_leave_save { background-color: #a6e3a1; color: #11111b; } 
    QPushButton#btn_scan_stop, QPushButton#btn_leave_delete { background-color: #f38ba8; color: #11111b; } 
    QPushButton#btn_user_edit { background-color: #cba6f7; color: #11111b; } 
    QPushButton#btn_refresh_att { background-color: #89dceb; color: #11111b; }

    /* Dashboard Cards */
    QWidget#card_1, QWidget#card_2, QWidget#card_3, QWidget#card_4 { background-color: #313244; border-radius: 12px; border: 1px solid #45475a; }
    QLabel.card_title { font-size: 16px; color: #a6adc8; font-weight: bold; }
    QLabel.card_value { font-size: 42px; font-weight: bold; }
    QLabel#val_total { color: #89b4fa; }
    QLabel#val_present { color: #a6e3a1; }
    QLabel#val_late { color: #f38ba8; }
    QLabel#val_leave { color: #f9e2af; }

    /* Labels */
    QLabel { font-weight: bold; }
    QLabel#lbl_reg_preview, QLabel#lbl_live_camera, QLabel#lbl_res_image { border: 2px dashed #45475a; background-color: #181825; border-radius: 10px; }
    QLabel#lbl_res_name { font-size: 24px; color: #89b4fa; }
    QLabel#lbl_status { font-size: 16px; color: #a6e3a1; }

    /* Table Widget Styling */
    QTableWidget { background-color: #181825; alternate-background-color: #1e1e2e; color: #cdd6f4; gridline-color: #45475a; border: 1px solid #313244; border-radius: 5px; outline: 0; }
    QTableWidget::item:selected { background-color: #89b4fa; color: #11111b; }
    QHeaderView::section { background-color: #313244; color: #a6adc8; padding: 8px; border: none; border-right: 1px solid #45475a; border-bottom: 1px solid #45475a; font-weight: bold; font-size: 13px; }
   </string>
