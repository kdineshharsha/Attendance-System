        <item>
         <widget class="QTabWidget" name="tabWidget_attendance">
          <property name="currentIndex"><number>0</number></property>
          <widget class="QWidget" name="tab_daily_logs">
           <attribute name="title"><string>🕒 Daily Logs</string></attribute>
           <layout class="QVBoxLayout" name="verticalLayout_logs">
            <item>
             <layout class="QHBoxLayout" name="horizontalLayout_att_top">
              <item><widget class="QLabel" name="lbl_att_title"><property name="font"><font><family>Segoe UI</family><bold>true</bold></font></property><property name="styleSheet"><string>color: #a6e3a1;</string></property><property name="text"><string>Today's Physical Scans</string></property></widget></item>
